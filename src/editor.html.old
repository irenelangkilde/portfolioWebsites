<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Portfolio — Irene's Webworks</title>
  <link rel="stylesheet" href="https://unpkg.com/grapesjs@0.21.13/dist/css/grapes.min.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; padding-top: 84px; }

    #toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 16px;
      background: #16213e;
      color: white;
      height: 48px;
      border-bottom: 1px solid rgba(255,255,255,.1);
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 9999;
    }
    #toolbar h1 {
      font-size: 15px;
      font-weight: 600;
      flex: 1;
      opacity: .9;
    }
    .tbtn {
      padding: 6px 14px;
      border: none;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .tbtn-ghost   { background: rgba(255,255,255,.12); color: #fff; }
    .tbtn-ghost:hover  { background: rgba(255,255,255,.22); }
    .tbtn-primary { background: #667eea; color: #fff; }
    .tbtn-primary:hover { background: #5568d4; }
    .tbtn-green   { background: #3a9e6e; color: #fff; }
    .tbtn-green:hover  { background: #2f8259; }

    #colorBar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: #0f172a;
      border-bottom: 1px solid rgba(255,255,255,.08);
      flex-wrap: wrap;
    }
    #colorBar label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: rgba(255,255,255,.6);
      cursor: pointer;
    }
    #colorBar input[type="color"] {
      width: 26px;
      height: 22px;
      border: 1px solid rgba(255,255,255,.2);
      border-radius: 4px;
      padding: 1px;
      background: none;
      cursor: pointer;
    }
    #colorBar .sep { width: 1px; height: 20px; background: rgba(255,255,255,.15); margin: 0 2px; }
    /* GrapesJS canvas height accounts for both toolbar + color bar */

    /* Give GrapesJS the full remaining height (toolbar 48px + color bar 36px) */
    #gjs { height: calc(100vh - 84px); }

    /* Force the GrapesJS canvas iframe to fill the full canvas height so that
       `100vh` inside the iframe matches the canvas height, not the content height.
       Without this, `height: 100vh` hero sections shrink to content height and
       hide top/bottom accent elements. */
    .gjs-cv-canvas,
    .gjs-frame-wrapper,
    .gjs-frame { height: 100% !important; min-height: 100% !important; }

    /* Prevent GrapesJS default gray canvas background from showing at edges */
    .gjs-cv-canvas { background: #1a1a2e !important; }

    /* Hide all GrapesJS chrome — we use our own toolbar */
    .gjs-pn-panels,
    .gjs-devices-c,
    .gjs-device-label,
    .gjs-rte-toolbar { display: none !important; }

#no-preview {
      display: none;
      position: fixed; inset: 0;
      background: #1a1a2e;
      color: white;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      font-size: 16px;
    }
  </style>
</head>
<body>

  <div id="toolbar">
    <h1>Irene's Webworks — Visual Editor</h1>
    <button class="tbtn tbtn-ghost"   id="btnBack">← Back to Form</button>
    <button class="tbtn tbtn-green"   id="btnToggleEdit">✏️ Edit</button>
    <button class="tbtn tbtn-primary" id="btnDownload">Download HTML</button>
  </div>

  <div id="colorBar">
    <label>1 <input type="color" id="cp1" /></label>
    <label>2 <input type="color" id="cp2" /></label>
    <label>3 <input type="color" id="cp3" /></label>
    <label>4 <input type="color" id="cp4" /></label>
    <label>5 <input type="color" id="cp5" /></label>
    <div class="sep"></div>
    <button class="tbtn tbtn-ghost" id="btnResetColors" style="font-size:12px; padding:4px 10px;">↺ Reset to page 4 defaults</button>
  </div>

  <div id="gjs"></div>

  <!-- Floating attribute editor — appears when a link or image is selected in edit mode -->
  <div id="attrBar" style="
      display: none;
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: #16213e;
      color: #fff;
      padding: 10px 16px;
      border-radius: 10px;
      gap: 10px;
      align-items: center;
      z-index: 99999;
      box-shadow: 0 6px 28px rgba(0,0,0,.5);
      font-size: 13px;
      white-space: nowrap;
  ">
    <span id="attrLabel" style="opacity:.75;">🔗 href:</span>
    <input id="attrInput" type="text" style="
        width: 320px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.25);
        border-radius: 5px;
        color: #fff;
        padding: 5px 9px;
        font-size: 13px;
        outline: none;
    " placeholder="https://…" />
    <button id="attrApply" style="
        background: #667eea;
        color: #fff;
        border: none;
        border-radius: 5px;
        padding: 6px 14px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
    ">Apply</button>
    <button id="attrClose" style="
        background: rgba(255,255,255,.12);
        color: #fff;
        border: none;
        border-radius: 5px;
        padding: 6px 10px;
        cursor: pointer;
        font-size: 13px;
    ">✕</button>
  </div>

  <div id="no-preview">
    <p>No portfolio found. Please generate one on Page 3 first.</p>
    <button class="tbtn tbtn-primary" onclick="window.close()">← Close</button>
  </div>

  <script src="https://unpkg.com/grapesjs@0.21.13/dist/grapes.min.js"></script>
  <script>
    const fullHtml    = localStorage.getItem("portfolio_preview_html");
    const headshotUrl = localStorage.getItem("portfolio_headshot_dataurl");
    const page4Colors = JSON.parse(localStorage.getItem("portfolio_page4_colors") || "null");
    // Slot order matches page 4: primary, secondary, accent, dark, light
    const COLOR_SLOTS = ["primary", "secondary", "accent", "dark", "light"];
    const colorPickers = [
      document.getElementById("cp1"),
      document.getElementById("cp2"),
      document.getElementById("cp3"),
      document.getElementById("cp4"),
      document.getElementById("cp5"),
    ];

    if (!fullHtml) {
      document.getElementById("no-preview").style.display = "flex";
      document.getElementById("gjs").style.display = "none";
      document.getElementById("toolbar").style.display = "none";
    } else {
      let html = fullHtml;
      const headshotName = localStorage.getItem("portfolio_headshot_name");
      if (headshotUrl && headshotName) {
        html = html.replace(
          new RegExp(`src=['"]${CSS.escape(headshotName)}['"]`, "g"),
          `src="${headshotUrl}"`
        );
      }

      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");
      const bodyHtml = doc.body.innerHTML;
      const css = Array.from(doc.querySelectorAll("style"))
        .map(s => s.textContent)
        .join("\n");

      const editor = grapesjs.init({
        container: "#gjs",
        height: "calc(100vh - 48px)",
        storageManager: false,
        panels: { defaults: [] },   // remove all built-in GrapesJS panels
        deviceManager: false,       // no device switcher UI
        components: bodyHtml,
        style: css
      });

      // ── Color bar ─────────────────────────────────────────────────────────
      // Reads --color-1…--color-5 (or page 4 slots as fallback) from the
      // generated HTML and lets the user live-edit them in the iframe.

      function getIframeDoc() {
        try { return editor.Canvas.getFrameEl()?.contentDocument; } catch { return null; }
      }

      // Read computed value of a CSS variable from the iframe :root
      function readCssVar(doc, name) {
        try {
          return getComputedStyle(doc.documentElement).getPropertyValue(name).trim();
        } catch { return ""; }
      }

      // Apply a hex color to a CSS variable in the iframe
      function setCssVar(name, hex) {
        const doc = getIframeDoc();
        if (!doc) return;
        doc.documentElement.style.setProperty(name, hex);
      }

      // Detect which CSS variable names the template actually uses for its 5 color slots
      function detectColorVarNames(doc) {
        if (!doc) return [];
        const style = doc.documentElement.getAttribute("style") || "";
        const rootText = Array.from(doc.querySelectorAll("style"))
          .map(s => s.textContent).join("\n");
        // Look for --color-1…--color-5 first (our standard), then --color1…--color5
        for (const pattern of [
          ["--color-1","--color-2","--color-3","--color-4","--color-5"],
          ["--color1","--color2","--color3","--color4","--color5"],
        ]) {
          if (pattern.every(v => rootText.includes(v))) return pattern;
        }
        return [];
      }

      let colorVarNames = []; // filled on editor load

      function initColorBar() {
        const doc = getIframeDoc();
        colorVarNames = detectColorVarNames(doc);

        // Seed pickers: try reading current CSS vars, fall back to page 4 values
        colorPickers.forEach((picker, i) => {
          if (!picker) return;
          let val = colorVarNames[i] ? readCssVar(doc, colorVarNames[i]) : "";
          if (!val && page4Colors) val = page4Colors[COLOR_SLOTS[i]] || "";
          if (val) picker.value = val.startsWith("#") ? val : rgbToHex(val);
        });
      }

      function rgbToHex(rgb) {
        const m = rgb.match(/\d+/g);
        if (!m || m.length < 3) return "#000000";
        return "#" + m.slice(0,3).map(n => parseInt(n).toString(16).padStart(2,"0")).join("");
      }

      colorPickers.forEach((picker, i) => {
        if (!picker) return;
        picker.addEventListener("input", () => {
          if (colorVarNames[i]) setCssVar(colorVarNames[i], picker.value);
        });
      });

      document.getElementById("btnResetColors").onclick = () => {
        if (!page4Colors) return;
        const doc = getIframeDoc();
        colorPickers.forEach((picker, i) => {
          if (!picker) return;
          const hex = page4Colors[COLOR_SLOTS[i]];
          if (!hex) return;
          picker.value = hex;
          if (colorVarNames[i]) setCssVar(colorVarNames[i], hex);
        });
      };

      let isPreviewing = false; // GrapesJS starts in edit mode; we switch to preview on load

      editor.on("load", () => {
        // GrapesJS expands `background: gradients, #color` shorthand into
        // `background-image: gradients, initial; background-color: #color` — the `initial`
        // in a comma-separated background-image list is invalid CSS and the browser drops
        // the entire declaration, leaving a white canvas. Fix: append the original
        // (unmangled) CSS into the iframe so it takes precedence via source order.
        try {
          const iframeDoc = editor.Canvas.getFrameEl()?.contentDocument;
          if (iframeDoc?.head) {
            const fix = iframeDoc.createElement("style");
            fix.textContent = css;
            iframeDoc.head.appendChild(fix);
          }
        } catch (e) { /* cross-origin or not ready — ignore */ }

        // Seed color pickers from the loaded template's CSS variables
        initColorBar();

        // Start in preview mode using GrapesJS's built-in command, which disables
        // all edit-mode interaction (hover highlights, selection, etc.)
        editor.runCommand("core:preview");
        isPreviewing = true;
        const btn = document.getElementById("btnToggleEdit");
        btn.textContent = "✏️ Edit";
        btn.className = "tbtn tbtn-green";
      });

      document.getElementById("btnToggleEdit").onclick = () => {
        const btn = document.getElementById("btnToggleEdit");
        if (isPreviewing) {
          editor.stopCommand("core:preview");
          btn.textContent = "👁 Preview";
          btn.className = "tbtn tbtn-ghost";
        } else {
          editor.runCommand("core:preview");
          btn.textContent = "✏️ Edit";
          btn.className = "tbtn tbtn-green";
          hideAttrBar(); // hide when switching to preview
        }
        isPreviewing = !isPreviewing;
      };

      // ── Floating attribute editor ──────────────────────────────────────────
      // Maps tag name → { attr, label } for the attributes we expose.
      const EDITABLE_ATTRS = {
        a:   { attr: "href",   label: "🔗 href:" },
        img: { attr: "src",    label: "🖼 src:"  }
      };

      const attrBar   = document.getElementById("attrBar");
      const attrLabel = document.getElementById("attrLabel");
      const attrInput = document.getElementById("attrInput");
      let   attrComp  = null;

      function showAttrBar(comp) {
        const tag  = (comp.get("tagName") || "").toLowerCase();
        const cfg  = EDITABLE_ATTRS[tag];
        if (!cfg) { hideAttrBar(); return; }
        attrComp        = comp;
        attrLabel.textContent = cfg.label;
        attrInput.value = comp.getAttributes()[cfg.attr] || "";
        attrBar.style.display = "flex";
        attrInput.focus();
      }

      function hideAttrBar() {
        attrBar.style.display = "none";
        attrComp = null;
      }

      function applyAttr() {
        if (!attrComp) return;
        const tag = (attrComp.get("tagName") || "").toLowerCase();
        const cfg = EDITABLE_ATTRS[tag];
        if (!cfg) return;
        attrComp.addAttributes({ [cfg.attr]: attrInput.value.trim() });
        hideAttrBar();
      }

      editor.on("component:selected", comp => {
        if (!isPreviewing) showAttrBar(comp);
      });
      editor.on("component:deselected", hideAttrBar);

      document.getElementById("attrApply").onclick = applyAttr;
      document.getElementById("attrClose").onclick = hideAttrBar;
      attrInput.addEventListener("keydown", e => { if (e.key === "Enter") applyAttr(); });

      document.getElementById("btnBack").onclick = () => {
        if (window.opener) { window.opener.focus(); }
        window.close();
      };

      document.getElementById("btnDownload").onclick = () => {
        // Use the original HTML directly — GrapesJS mangles background CSS shorthand
        // (adds invalid `initial` to background-image lists), so editor.getCss() would
        // produce a broken file. The original fullHtml has already been post-processed
        // server-side and is safe to download as-is.
        const blob = new Blob([fullHtml], { type: "text/html;charset=utf-8" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "portfolio.html";
        a.click();
        URL.revokeObjectURL(a.href);
      };
    }
  </script>
</body>
</html>
