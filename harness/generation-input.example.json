{
  "name": "slot-fill-local",
  "description": "Copy this file to harness/generation-input.local.json and replace the payload with the exact inputs you want rerun.",
  "outputDir": "harness/runs/slot-fill-local",
  "watch": [
    "templates/owen/annotated.html"
  ],
  "payload": {
    "mode": "slot-fill",
    "provider": "claude",
    "sampleHtmlFile": "templates/owen/annotated.html",
    "page1": {
      "major": "Electrical Engineering",
      "specialization": "lasers",
      "template_source": "keyword",
      "model_template": "Owen",
      "template_copyright_mode": "owned"
    },
    "colorSpec": {
      "use_sample_colors": false,
      "background": "#fbf7f3",
      "foreground": "#1f1a16",
      "primary": "#5c514a",
      "secondary": "#b8744f",
      "accent": "#e2beab"
    },
    "resumeFacts": {
      "personal": {
        "name": "Test User",
        "email": "test@example.com"
      },
      "summary": "Electrical engineering graduate with hands-on laser systems, RF testing, and troubleshooting experience.",
      "education": [
        {
          "institution": "Example University",
          "degree": "BS",
          "major": "Electrical Engineering",
          "graduation_date": "April 2027"
        }
      ],
      "experience": [
        {
          "company": "Photonics Lab",
          "title": "Laser Systems Intern",
          "bullets": [
            "Aligned optical components for experimental laser setups.",
            "Used oscilloscopes and RF equipment to troubleshoot signal issues."
          ],
          "technologies": ["laser systems", "oscilloscope", "RF testing"]
        }
      ],
      "projects": [
        {
          "name": "Laser Control Bench",
          "description": "Built a control and testing bench for laser hardware diagnostics.",
          "bullets": [
            "Integrated microcontroller controls with measurement equipment.",
            "Documented repeatable troubleshooting procedures."
          ],
          "technologies": ["embedded systems", "optics", "test equipment"]
        }
      ],
      "skills": {
        "technical": ["laser systems", "electronics troubleshooting", "RF testing"],
        "tools": ["oscilloscope", "multimeter"],
        "programming_languages": ["Python", "C"]
      }
    },
    "resolvedStrategy": {
      "role_title": "Field Service Engineer",
      "company": "Sciton",
      "industry": "Medical laser equipment",
      "headline": "Laser hardware experience. Electronic troubleshooting. Ready for the field.",
      "summary": "Position the candidate as a practical electrical engineering graduate ready to support laser hardware in the field.",
      "target_keywords": ["laser systems", "RF testing", "field service", "troubleshooting"],
      "motifs": {
        "broad_primary_domain": "electrical engineering",
        "potential_visual_motifs": ["laser optics", "test bench", "signal traces"]
      }
    }
  },
  "assertions": {
    "status": "done",
    "minSiteHtmlLength": 5000,
    "siteHtmlMustInclude": [
      "Electrical Engineering"
    ]
  }
}
